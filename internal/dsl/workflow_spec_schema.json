{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowSpec",
  "type": "object",
  "required": ["spec_version", "generator_version", "intent", "mode", "nodes", "edges", "outputs"],
  "properties": {
    "spec_version": { "type": "string", "minLength": 1 },
    "generator_version": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["quality", "balanced", "cost"] },
    "global_constraints": {
      "type": "object",
      "properties": {
        "data_classification": { "type": "string", "enum": ["public", "internal", "confidential", "restricted"] },
        "max_total_cost_usd": { "type": "number", "minimum": 0 },
        "max_wall_time_sec": { "type": "integer", "minimum": 1 }
      },
      "required": ["data_classification"],
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["planner", "llm_task", "evaluator", "merge", "finalizer"] },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "inputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string", "enum": ["intent", "node_output"] },
                "node_id": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "expected_artifact_type": { "type": "string" },
          "output_schema": { "type": ["object", "boolean"] },
          "routing_profile": { "type": "string", "enum": ["quality", "balanced", "cost"] },
          "retry_policy": {
            "type": "object",
            "properties": { "max_attempts": { "type": "integer", "minimum": 0 } },
            "additionalProperties": true
          },
          "fallback_chain": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["model", "on"],
              "properties": {
                "model": { "type": "string", "minLength": 1 },
                "on": { "type": "string", "enum": ["any_error", "validation_fail", "empty_or_too_short"] }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "condition"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "condition": { "type": "string", "enum": ["always", "on_success", "on_failure"] }
        },
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "from_node_id"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "from_node_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

